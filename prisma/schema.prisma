datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("USER")
  profile   Profile?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age            Int
  gender         String
  height         Float
  weight         Float
  medicalHistory String
  allergies      String
  healthGoals    String
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}
